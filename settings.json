{
  "autoUpdatesChannel": "latest",
  "theme": "dark",
  "permissions": {
    "allow": [
      "Bash(git log:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git branch:*)",
      "Bash(git show:*)",
      "Bash(git remote:*)",
      "Bash(ls:*)",
      "Bash(node --version:*)",
      "Bash(npm --version:*)",
      "Bash(npm list:*)",
      "Bash(Get-ChildItem:*)",
      "Bash(echo:*)"
    ]
  }
}
